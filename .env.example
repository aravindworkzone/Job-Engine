# =========================================================================
# Stage 0 — build profile.json from resume.pdf
# =========================================================================

# Which engine Stage 0 uses to parse the resume:
# anthropic (Claude, reads the PDF natively) | groq (OpenAI-compatible, text-only)
LLM_PROVIDER=anthropic

# ---- Anthropic (Claude) — native PDF reading ----
# Key from https://console.anthropic.com/ (starts with sk-ant-).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Groq (OpenAI-compatible) — text-only; the resume PDF is text-extracted first ----
# Key from https://console.groq.com/keys (starts with gsk_).
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# =========================================================================
# Stage 1 — enrich profile.json into enriched.json
# Resume (Stage 0) + Notion are MANDATORY. The rest are optional — turn off with:
# STAGE1_GITHUB=off
# STAGE1_PORTFOLIO=off
# STAGE1_FOOTPRINT=off
# =========================================================================

# ---- Notion ---- (internal integration token; share the Job Hunt DB with it)
# Key from https://www.notion.so/my-integrations (starts with ntn_ or secret_).
# The 🎯 Job Hunt DB is the ONLY Notion DB used (mandatory; auto-created if
# missing). Override its id with NOTION_JOBHUNT_DB in the Stage 2 section below.
NOTION_TOKEN=

# ---- GitHub ---- (optional token: raises rate limit + enables pinned-repo lookup)
# Fine-grained or classic PAT from https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_USERNAME=aravindworkzone

# ---- Portfolio ----
PORTFOLIO_URL=https://aravind-mern.vercel.app

# ---- Public footprint ---- (Exa primary, Tavily fallback)
# Exa key from https://dashboard.exa.ai/ ; Tavily key from https://app.tavily.com/
EXA_API_KEY=
TAVILY_API_KEY=

# =========================================================================
# Stage 2 — source jobs into data/jobs.json  (no key = that source is skipped)
#
# Source tiers (registry: SOURCE_ROLES in src/controller/search.controller.js).
# No source is mandatory — a dead one is retried (SOURCE_RETRIES), then skipped;
# the run ALWAYS completes on whatever survives. But they are not equal:
#
#   CRITICAL — JSearch + Jooble are the engine; together they can run the
#              whole search. The orchestrator warns loudly when one dies.
#     - JSearch: quality. Google-for-Jobs aggregation (LinkedIn/Indeed/Naukri).
#       Paid RapidAPI quota → ONE query on the primary location only.
#     - Jooble: volume. Thousands of boards, loops EVERY location — it alone
#       covers the non-primary cities (Coimbatore/Bengaluru).
#   BACKUP — free redundancy so one critical outage never blinds a city:
#     - Adzuna: also the only free source with NUMERIC INR salaries (feeds
#       the salary scoring). Recommended to register.
#     - Careerjet: free breadth, overlaps Jooble/Adzuna.
#   USEFUL — TheirStack: tech-stack-matched leads, 200 free credits/month.
#   REDUNDANT — SerpApi: scrapes Google-for-Jobs like JSearch; don't pay twice.
#   SITUATIONAL — Apify (needs token + actor id); Arbeitnow (remote-only,
#     keyless, auto-included only when a target role mentions "remote").
# =========================================================================
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
CAREERJET_AFFID=
JSEARCH_RAPIDAPI_KEY=
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_ALLJOBS_ACTOR_ID=
THEIRSTACK_API_KEY=
# Optional tuning (all knobs live in src/controller/ — see CLAUDE.md):
# JOB_LOCATIONS=Chennai,Coimbatore,Bengaluru   # priority order drives scoring too
# SALARY_BAND_LPA=4,6                # target band; scoring bonuses follow it
# JOB_COUNTRY=in                     # source-API country code
# EXTRA_REJECT_KEYWORDS=             # extra hard-reject terms, comma-separated
# STAGE2_MIN_SCORE=0                 # drop scored jobs below this before storing
# SOURCE_RETRIES=2                   # retries per dead source before skipping it this run
# SOURCE_RETRY_DELAY_MS=1000         # pause between source retry attempts
# STAGE1_MAX_AGE_DAYS=2              # enriched.json refresh window
# STAGE2_MAX_AGE_DAYS=3              # how old an enriched.json Stage 2 prefers
# NOTION_JOBHUNT_DB=6e50df73695b4c94a101eb95fa3f8a50   # override the Job Hunt DB id
# If the Job Hunt DB is missing/unshared, the pipeline finds it by name or
# auto-creates "🎯 Job Hunt" under an accessible page (id cached in data/notionState.json).

# =========================================================================
# Stage 3 — verify jobs (uses TAVILY_API_KEY above for career-page discovery)
# =========================================================================
# STAGE3_COMPANIES_PER_RUN=10        # cap companies verified per run (credit discipline)

# Stage 4 (push to Notion) reuses NOTION_TOKEN from the Stage 1 section.

# =========================================================================
# Pipeline start (npm run search) — clean-slate reset + run history
# =========================================================================
# Every pipeline start wipes all *.log and data/*.json EXCEPT profile.json and
# the runs log. runs.log is APPEND-ONLY: it records the date & time of every
# run and is never deleted or rewritten by anything in the pipeline.
# PIPELINE_RESET_ON_START=on        # off = keep previous run's files
# PIPELINE_RESET_KEEP=              # extra basenames to protect, comma-separated
# RUNS_LOG_FILE=runs.log            # name of the append-only run-history file
