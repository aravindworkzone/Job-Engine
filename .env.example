# =========================================================================
# Stage 0 — build profile.json from resume.pdf
# =========================================================================

# Which engine Stage 0 uses to parse the resume:
# anthropic (Claude, reads the PDF natively) | groq (OpenAI-compatible, text-only)
LLM_PROVIDER=anthropic

# ---- Anthropic (Claude) — native PDF reading ----
# Key from https://console.anthropic.com/ (starts with sk-ant-).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Groq (OpenAI-compatible) — text-only; the resume PDF is text-extracted first ----
# Key from https://console.groq.com/keys (starts with gsk_).
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# =========================================================================
# Stage 1 — enrich profile.json into enriched.json
# =========================================================================

# ---- Notion ---- (internal integration token; share the 3 DBs with it)
# Key from https://www.notion.so/my-integrations (starts with ntn_ or secret_).
NOTION_TOKEN=
# DB IDs are hardcoded defaults in fetchNotion.js — only set these to override:
# NOTION_DB_SKILL_LEVELS=
# NOTION_DB_LINKEDIN_POSTS=
# NOTION_DB_JOB_HUNT=

# ---- GitHub ---- (optional token: raises rate limit + enables pinned-repo lookup)
# Fine-grained or classic PAT from https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_USERNAME=aravindworkzone

# ---- Portfolio ----
PORTFOLIO_URL=https://aravind-mern.vercel.app

# ---- Public footprint ---- (Exa primary, Tavily fallback)
# Exa key from https://dashboard.exa.ai/ ; Tavily key from https://app.tavily.com/
EXA_API_KEY=
TAVILY_API_KEY=

# =========================================================================
# Stage 2 — source jobs into data/jobs.json  (no key = that source is skipped)
# =========================================================================
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
CAREERJET_AFFID=
JSEARCH_RAPIDAPI_KEY=
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_ALLJOBS_ACTOR_ID=
THEIRSTACK_API_KEY=
# Optional tuning:
# STAGE2_MIN_SCORE=0                 # drop scored jobs below this before storing
# NOTION_JOBHUNT_DB=6e50df73695b4c94a101eb95fa3f8a50   # override the Job Hunt DB id

# =========================================================================
# Stage 3 — verify jobs (uses TAVILY_API_KEY above for career-page discovery)
# =========================================================================
# STAGE3_COMPANIES_PER_RUN=10        # cap companies verified per run (credit discipline)

# Stage 4 (push to Notion) reuses NOTION_TOKEN from the Stage 1 section.
